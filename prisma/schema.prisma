generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProductType {
  app
  model
  agent
  skill
  tutorial
  video
}

model User {
  id           String          @id @default(cuid())
  /// 登录用户名（唯一、不可改）
  handle       String          @unique
  /// 唯一好友码（不可改，加好友用，如 SP-7K3M9Q）
  friendCode   String?         @unique
  /// 展示昵称（可改、可重名）
  name         String
  /// salt:hash（scrypt）；种子好友可为空表示不可登录
  passwordHash String?
  avatarHue    Int
  /// 上传头像（data URL，压缩后）；为空则用色相头像
  avatarUrl    String?
  /// 平台管理员（可进 /admin 上架下架、设精选、编辑任意产品）
  isAdmin      Boolean         @default(false)
  level        Int
  signature    String          @default("")
  tokenBalance String          @default("0")
  /// 平台点数余额（购买产品用；未来支付系统充值入口）
  credits      Int             @default(1000)
  /// [{ label, icon }]
  badges       Json            @default("[]")
  /// 展柜精选的产品 slug
  showcase     String[]        @default([])
  /// 真实在线信号（ISO 字符串）：最近活跃时间
  lastSeenAt   String?
  /// 真实在线信号：当前正在使用的应用名 + 设置时刻
  currentActivity String?
  activityAt   String?
  /// 种子/兜底展示状态（好友未真实登录时使用）：online|using|meeting|offline
  presenceKind String          @default("offline")
  presenceDetail String?
  library      LibraryEntry[]
  friendsOut   FriendEdge[]    @relation("FriendA")
  friendsIn    FriendEdge[]    @relation("FriendB")
  credentials  ApiCredential[]
  usage        UsageRecord[]
  appStorage   AppStorage[]
  achievements AchievementUnlock[]
  messagesSent     Message[]   @relation("MsgFrom")
  messagesReceived Message[]   @relation("MsgTo")
}

/// 好友备注（我给某好友起的别名，仅自己可见）
model FriendNote {
  id           String @id @default(cuid())
  ownerUserId  String
  targetUserId String
  remark       String

  @@unique([ownerUserId, targetUserId])
}

model Message {
  id     String  @id @default(cuid())
  fromId String
  toId   String
  body   String
  /// text | image | file
  kind   String  @default("text")
  /// 图片/文档的 dataURL（压缩后）
  attachmentUrl  String?
  /// 文档原始文件名
  attachmentName String?
  /// ISO 字符串
  at     String
  read   Boolean @default(false)
  from   User    @relation("MsgFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to     User    @relation("MsgTo", fields: [toId], references: [id], onDelete: Cascade)

  @@index([fromId, toId, at])
}

model FriendEdge {
  id     String @id @default(cuid())
  aId    String
  bId    String
  status String @default("accepted")
  a      User   @relation("FriendA", fields: [aId], references: [id], onDelete: Cascade)
  b      User   @relation("FriendB", fields: [bId], references: [id], onDelete: Cascade)

  @@unique([aId, bId])
}

model Product {
  id           String         @id
  slug         String         @unique
  type         ProductType
  name         String
  tagline      String
  /// 段落数组
  description  String[]
  hueA         Int
  hueB         Int
  icon         String
  /// 真实媒体（有则优先于渐变色块）：方形封面 / 宽幅 banner / 截图集 / 预告片
  capsuleUrl   String?
  bannerUrl    String?
  screenshotUrls String[] @default([])
  /// 预告视频地址（mp4 直链或可嵌入的 URL）
  trailerUrl   String?
  tags         String[]
  /// 展示用聚合（= base 社会证明 与平台内真实评测的混合值）
  ratingScore  Float
  ratingCount  Int
  /// 上架自带的历史评价社会证明（不以单条 Review 行存储），平台内新评测在此基础上混合
  baseRatingScore Float @default(0)
  baseRatingCount Int   @default(0)
  /// 近 10 期好评率（0-100）
  histogram    Int[]
  acquisitions Int
  developer    String
  version      String?
  /// 应用入口（部署地址）
  entryUrl     String?
  /// 运行方式：embedded 沙箱 iframe 内运行 / newtab 新标签页打开
  launchMode   String   @default("embedded")
  /// null = 免费
  priceCredits Int?
  capabilities String[]
  releasedAt   String
  updatedAt    String
  featured     Boolean        @default(false)
  /// draft | published（仅 published 进商店列表）
  status       String         @default("published")
  /// 开发者归属（null = 官方/种子）
  ownerUserId  String?
  /// 开放 API / OAuth 应用凭证
  clientId         String?    @unique
  clientSecretHash String?
  reviews      Review[]
  inLibraries  LibraryEntry[]
  achievements Achievement[]
}

model Achievement {
  id          String              @id @default(cuid())
  productId   String
  /// 稳定 key（API 调用用）
  key         String
  name        String
  description String
  icon        String              @default("trophy")
  hidden      Boolean             @default(false)
  sort        Int                 @default(0)
  product     Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  unlocks     AchievementUnlock[]

  @@unique([productId, key])
}

/// 用户授权某应用使用「平台配置的 API 密钥」（沙箱应用的 ai.chat 首次询问，记住后跨应用通用）
model GatewayConsent {
  id        String @id @default(cuid())
  userId    String
  productId String
  createdAt String

  @@unique([userId, productId])
}

model ReviewVote {
  id       String @id @default(cuid())
  reviewId String
  userId   String

  @@unique([reviewId, userId])
}

model AchievementUnlock {
  id            String      @id @default(cuid())
  achievementId String
  userId        String
  at            String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([achievementId, userId])
  @@index([userId])
}

model StatRecord {
  id          String @id @default(cuid())
  productId   String
  userId      String
  /// playtime_minutes | 自定义 key
  key         String
  value       Int    @default(0)

  @@unique([productId, userId, key])
}

/// OAuth2 授权码 + 用户访问令牌（外部 web 应用用）
model OAuthGrant {
  id            String   @id @default(cuid())
  productId     String
  userId        String
  scopes        String[]
  code          String?  @unique
  codeExpiresAt String?
  accessToken   String?  @unique
  createdAt     String

  @@unique([productId, userId])
}

model Review {
  id         String  @id @default(cuid())
  productId  String
  /// 平台注册作者（防同一用户重复评测）；种子/Agent 评测为 null
  authorUserId String?
  /// 评测者去规范化（部分评测者非平台注册用户，如 Agent）
  authorName String
  avatarHue  Int
  isAgent    Boolean @default(false)
  score      Int
  usageHours Int
  helpful    Int     @default(0)
  body       String
  date       String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model LibraryEntry {
  id         String  @id @default(cuid())
  userId     String
  productId  String
  acquiredAt String
  lastUsedAt String?
  usageHours Int     @default(0)
  /// 更细粒度的累计使用时长（分钟）；UI 用它显示"X 分钟 / X 小时 Y 分钟"
  usageMinutes Int   @default(0)
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model ApiCredential {
  id              String  @id @default(cuid())
  userId          String
  /// anthropic | openai | google | xai | openrouter
  provider        String
  label           String
  /// AES-256-GCM 信封密文（base64(iv).base64(tag).base64(cipher)）
  ciphertext      String
  /// 展示用末 4 位
  last4           String
  /// 每日 token 上限；null = 不限
  dailyTokenLimit Int?
  createdAt       String
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, label])
}

model UsageRecord {
  id          String @id @default(cuid())
  userId      String
  /// 消耗发生在哪个应用
  productSlug String
  provider    String
  model       String
  tokensIn    Int
  tokensOut   Int
  costCents   Int
  /// YYYY-MM-DD
  day         String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, day])
}

model AppStorage {
  id          String @id @default(cuid())
  userId      String
  /// 应用隔离：每应用每用户独立命名空间
  productSlug String
  key         String
  value       String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productSlug, key])
}

model ActivityEvent {
  id           String  @id @default(cuid())
  actorName    String
  actorHue     Int
  actorIsAgent Boolean @default(false)
  verb         String
  productSlug  String?
  detail       String?
  /// Phase 1a 保留展示字符串（"12 分钟前"），Phase 1b 迁 DateTime
  at           String
  sort         Int
}

/// 首页顶部大活动横幅（管理员后台可编辑/上下架/排序）
model Banner {
  id        String  @id @default(cuid())
  title     String
  subtitle  String  @default("")
  /// 小标签，如"限时 · 即日起至 6 月 30 日"
  badge     String  @default("")
  imageUrl  String
  href      String  @default("/#featured")
  active    Boolean @default(true)
  sort      Int     @default(0)
  createdAt String
}
