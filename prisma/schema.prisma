generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProductType {
  app
  model
  agent
  skill
  tutorial
  video
}

model User {
  id           String          @id @default(cuid())
  /// 登录用户名（唯一、不可改）
  handle       String          @unique
  /// 唯一好友码（不可改，加好友用，8 位纯数字，如 73920184）
  friendCode   String?         @unique
  /// 展示昵称（可改、可重名）
  name         String
  /// salt:hash（scrypt）；种子好友可为空表示不可登录
  passwordHash String?
  avatarHue    Int
  /// 上传头像（data URL，压缩后）；为空则用色相头像
  avatarUrl    String?
  /// 平台管理员（可进 /admin 上架下架、设精选、编辑任意产品）
  isAdmin      Boolean         @default(false)
  level        Int
  signature    String          @default("")
  tokenBalance String          @default("0")
  /// 平台点数余额（购买产品用；未来支付系统充值入口）
  credits      Int             @default(1000)
  /// 平台 Gateway 预付 token 余额：用点数兑换，应用经平台 key 调模型时按用量扣减（multillm 等原生应用用）
  gatewayTokens Int            @default(0)
  /// [{ label, icon }]
  badges       Json            @default("[]")
  /// 展柜精选的产品 slug
  showcase     String[]        @default([])
  /// 真实在线信号（ISO 字符串）：最近活跃时间
  lastSeenAt   String?
  /// 真实在线信号：当前正在使用的应用名 + 设置时刻
  currentActivity String?
  /// 当前正在使用应用的 slug（好友右键可直达其商店页）
  currentActivitySlug String?
  activityAt   String?
  /// 种子/兜底展示状态（好友未真实登录时使用）：online|using|meeting|offline
  presenceKind String          @default("offline")
  presenceDetail String?
  /// 资料背景（好友悬停卡展示）：图片/GIF dataURL 或图片/mp4/webm 直链，可动态
  profileBannerUrl String?
  /// human | agent（agent = 用户创建的 AI 虚拟用户，复用整套聊天/群组/好友体系）
  kind         String          @default("human")
  /// agent 归属者（创建者）的 User.id
  agentOwnerId String?
  /// agent 形态：local（本地连接器驱动 Claude Code/Codex）| hosted（平台托管，走 AI Gateway）
  agentKind    String?
  /// agent 人设（托管 agent 的 system prompt；本地 agent 创建时写入其 CLAUDE.md）
  agentPersona String?
  /// 本地连接器令牌的 sha256（鉴权用，唯一索引 findUnique 命中）
  agentTokenHash String?         @unique
  /// 同一令牌的 AES-GCM 信封密文（仅展示给 owner：随时取回启动/重启命令，免重置令牌）
  agentTokenEnc  String?
  /// 连接器最近拉取时间（本地 agent 的在线判定）
  agentLastPollAt String?
  /// agent 可调设置（JSON）：provider/model/contextMsgs/maxHops/rateLimit/allowAgentMention/dmAutoReply/groupProactive/fullAuto/isolate
  agentSettings   Json?
  library      LibraryEntry[]
  wishlist     WishlistEntry[]
  creditTxns   CreditTransaction[]
  notifications Notification[]
  friendsOut   FriendEdge[]    @relation("FriendA")
  friendsIn    FriendEdge[]    @relation("FriendB")
  credentials  ApiCredential[]
  usage        UsageRecord[]
  appStorage   AppStorage[]
  achievements AchievementUnlock[]
  messagesSent     Message[]   @relation("MsgFrom")
  messagesReceived Message[]   @relation("MsgTo")
  groupMemberships ChatGroupMember[]
  groupMessages    GroupMessage[]
  reactions        MessageReaction[]
}

/// 消息表情反应（私聊+群聊合一，scope 区分；messageId 指向 Message.id 或 GroupMessage.id）
model MessageReaction {
  id        String @id @default(cuid())
  /// dm | group
  scope     String
  messageId String
  userId    String
  emoji     String
  at        String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scope, messageId, userId, emoji])
  @@index([scope, messageId])
}

/// 会话级实时信号（typing 心跳 + 已读游标），user × 会话(scope) 维度。scope: dm:<otherId> | ch:<channelId>
model ChatSignal {
  id        String  @id @default(cuid())
  userId    String
  scope     String
  /// 最近一次「我在该会话打字」的 ISO；过期(>5s)视为停止
  typingAt  String?
  /// 我在该会话已读到的最后消息时刻（ISO）
  readAt    String?
  /// scope=ch 时冗余 channelId，便于按频道聚合成员已读
  channelId String?

  @@unique([userId, scope])
  @@index([scope])
  @@index([channelId])
}

/// 语音房间在场（roomId = ChatChannel.id，kind=voice）。纯轮询同步，裸 http 可用
model VoiceParticipant {
  id         String  @id @default(cuid())
  roomId     String
  userId     String
  joinedAt   String
  /// 每轮 poll 刷新；服务端读时 6s 窗口判活（兜掉关页面没发离开）
  lastSeenAt String
  micOn      Boolean @default(true)
  speaking   Boolean @default(false)

  @@unique([roomId, userId])
  @@index([roomId])
}

/// 群组聊天（Steam 式 Group Chat：多人 + 多频道）
model ChatGroup {
  id        String            @id @default(cuid())
  /// 群名；空字符串 = 按成员名自动命名（"A、B 和 C"）
  name      String            @default("")
  /// 群简介（设置面板可编辑）
  description String          @default("")
  /// 群图标（上传图片 dataURL / 直链；空则用成员头像拼贴）
  iconUrl   String?
  ownerId   String
  createdAt String
  members   ChatGroupMember[]
  channels  ChatChannel[]
  messages  GroupMessage[]
}

model ChatGroupMember {
  id       String    @id @default(cuid())
  groupId  String
  userId   String
  joinedAt String
  group    ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
}

/// 群内频道：text 文字频道 / voice 语音频道（原型占位）
model ChatChannel {
  id       String         @id @default(cuid())
  groupId  String
  name     String
  kind     String         @default("text")
  sort     Int            @default(0)
  /// 频道简介 / 主题（频道头部展示）
  topic    String         @default("")
  /// 慢速模式：同一成员两条消息最小间隔秒数（0=关）
  slowmodeSec Int         @default(0)
  group    ChatGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  messages GroupMessage[]
}

/// Agent 收件队列：待某 agent 处理的消息（私聊必达；群聊被 @ 才投递）。
/// 连接器长轮询领取（领取即 done）；冗余存上下文让连接器零额外查询。
model AgentTask {
  id             String  @id @default(cuid())
  agentId        String
  /// dm | group
  kind           String
  fromHandle     String
  fromName       String
  body           String
  attachmentUrl  String?
  attachmentName String?
  groupId        String?
  groupName      String?
  channelId      String?
  channelName    String?
  /// agent 互相唤醒的链深（防死循环：超限不再扩散）
  hops           Int     @default(0)
  /// pending | done
  status         String  @default("pending")
  createdAt      String

  @@index([agentId, status, createdAt])
}

model GroupMessage {
  id             String      @id @default(cuid())
  groupId        String
  channelId      String
  fromId         String
  /// text | image | file | voice
  kind           String      @default("text")
  body           String
  attachmentUrl  String?
  attachmentName String?
  /// ISO 字符串
  at             String
  /// 编辑过则为最后编辑 ISO（UI 显示「已编辑」）
  editedAt       String?
  /// 软删除：保留行占位「此消息已删除」，不剔除（分页游标/未读 marker 依赖）
  deleted        Boolean     @default(false)
  /// 引用的消息 id（同表自引用）
  replyToId      String?
  /// 变更游标：create/edit/delete/反应增删 时刷新为 now；轮询用 updatedAt>since 取变更行
  updatedAt      String?
  group          ChatGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  channel        ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  from           User        @relation(fields: [fromId], references: [id], onDelete: Cascade)
  replyTo        GroupMessage?  @relation("GMReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies        GroupMessage[] @relation("GMReply")

  @@index([channelId, at])
  @@index([groupId, at])
  @@index([channelId, updatedAt])
}

/// 好友备注（我给某好友起的别名，仅自己可见）
model FriendNote {
  id           String @id @default(cuid())
  ownerUserId  String
  targetUserId String
  remark       String

  @@unique([ownerUserId, targetUserId])
}

model Message {
  id     String  @id @default(cuid())
  fromId String
  toId   String
  body   String
  /// text | image | file | voice
  kind   String  @default("text")
  /// 图片/文档/语音的 dataURL（压缩后）
  attachmentUrl  String?
  /// 文档原始文件名
  attachmentName String?
  /// ISO 字符串
  at     String
  read   Boolean @default(false)
  /// 编辑过则为最后编辑 ISO（UI 显示「已编辑」）
  editedAt   String?
  /// 软删除：保留行占位「此消息已删除」
  deleted    Boolean @default(false)
  /// 引用的消息 id（同表自引用）
  replyToId  String?
  /// 变更游标：轮询用 updatedAt>since 取变更行
  updatedAt  String?
  from   User    @relation("MsgFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to     User    @relation("MsgTo", fields: [toId], references: [id], onDelete: Cascade)
  replyTo Message?  @relation("MsgReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies Message[] @relation("MsgReply")

  @@index([fromId, toId, at])
  @@index([fromId, toId, updatedAt])
}

model FriendEdge {
  id     String @id @default(cuid())
  aId    String
  bId    String
  /// pending（a 申请 b）| accepted | ignored（b 忽略了 a 的申请，不再提示但保留）
  status String @default("accepted")
  /// 申请发起时间（ISO）：好友申请按此倒序展示
  createdAt  String @default("")
  /// 接受时间（ISO）：「最近添加」按此倒序展示
  acceptedAt String @default("")
  a      User   @relation("FriendA", fields: [aId], references: [id], onDelete: Cascade)
  b      User   @relation("FriendB", fields: [bId], references: [id], onDelete: Cascade)

  @@unique([aId, bId])
}

model Product {
  id           String         @id
  slug         String         @unique
  type         ProductType
  name         String
  tagline      String
  /// 段落数组
  description  String[]
  hueA         Int
  hueB         Int
  icon         String
  /// 真实媒体（有则优先于渐变色块）：方形封面 / 宽幅 banner / 截图集 / 预告片
  capsuleUrl   String?
  bannerUrl    String?
  screenshotUrls String[] @default([])
  /// 预告视频地址（mp4 直链或可嵌入的 URL）
  trailerUrl   String?
  tags         String[]
  /// 展示用聚合（= base 社会证明 与平台内真实评测的混合值）
  ratingScore  Float
  ratingCount  Int
  /// 上架自带的历史评价社会证明（不以单条 Review 行存储），平台内新评测在此基础上混合
  baseRatingScore Float @default(0)
  baseRatingCount Int   @default(0)
  /// 近 10 期好评率（0-100）
  histogram    Int[]
  acquisitions Int
  developer    String
  version      String?
  /// 应用入口（部署地址）；托管单页应用时指向 /api/apps/<slug>/serve
  entryUrl     String?
  /// 平台托管的单页应用 HTML（上传后存这里，经 serve 路由在沙箱内运行；为空=外部部署应用）
  hostedHtml   String?
  /// 运行方式：embedded 沙箱 iframe 内运行 / newtab 新标签页打开
  launchMode   String   @default("embedded")
  /// null = 免费
  priceCredits Int?
  /// 限时折扣百分比（0-90）；>0 时商店显示原价划线 + 折后价 + "-X%"
  discountPct  Int      @default(0)
  capabilities String[]
  releasedAt   String
  updatedAt    String
  featured     Boolean        @default(false)
  /// draft | published（仅 published 进商店列表）
  status       String         @default("published")
  /// 开发者归属（null = 官方/种子）
  ownerUserId  String?
  /// 开放 API / OAuth 应用凭证
  clientId         String?    @unique
  clientSecretHash String?
  reviews      Review[]
  inLibraries  LibraryEntry[]
  wishlistedBy WishlistEntry[]
  achievements Achievement[]
}

model Achievement {
  id          String              @id @default(cuid())
  productId   String
  /// 稳定 key（API 调用用）
  key         String
  name        String
  description String
  icon        String              @default("trophy")
  hidden      Boolean             @default(false)
  sort        Int                 @default(0)
  product     Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  unlocks     AchievementUnlock[]

  @@unique([productId, key])
}

/// 用户授权某应用使用「平台配置的 API 密钥」（沙箱应用的 ai.chat 首次询问，记住后跨应用通用）
model GatewayConsent {
  id        String @id @default(cuid())
  userId    String
  productId String
  createdAt String

  @@unique([userId, productId])
}

model ReviewVote {
  id       String @id @default(cuid())
  reviewId String
  userId   String

  @@unique([reviewId, userId])
}

model AchievementUnlock {
  id            String      @id @default(cuid())
  achievementId String
  userId        String
  at            String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([achievementId, userId])
  @@index([userId])
}

model StatRecord {
  id          String @id @default(cuid())
  productId   String
  userId      String
  /// playtime_minutes | 自定义 key
  key         String
  value       Int    @default(0)

  @@unique([productId, userId, key])
}

/// OAuth2 授权码 + 用户访问令牌（外部 web 应用用）
model OAuthGrant {
  id            String   @id @default(cuid())
  productId     String
  userId        String
  scopes        String[]
  code          String?  @unique
  codeExpiresAt String?
  accessToken   String?  @unique
  createdAt     String

  @@unique([productId, userId])
}

model Review {
  id         String  @id @default(cuid())
  productId  String
  /// 平台注册作者（防同一用户重复评测）；种子/Agent 评测为 null
  authorUserId String?
  /// 评测者去规范化（部分评测者非平台注册用户，如 Agent）
  authorName String
  avatarHue  Int
  isAgent    Boolean @default(false)
  score      Int
  usageHours Int
  helpful    Int     @default(0)
  body       String
  date       String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

/// 心愿单（关注但未获取的产品；Steam 式）
model WishlistEntry {
  id        String  @id @default(cuid())
  userId    String
  productId String
  createdAt String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model LibraryEntry {
  id         String  @id @default(cuid())
  userId     String
  productId  String
  acquiredAt String
  lastUsedAt String?
  usageHours Int     @default(0)
  /// 更细粒度的累计使用时长（分钟）；UI 用它显示"X 分钟 / X 小时 Y 分钟"
  usageMinutes Int   @default(0)
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model ApiCredential {
  id              String  @id @default(cuid())
  userId          String
  /// anthropic | openai | google | xai | openrouter
  provider        String
  label           String
  /// AES-256-GCM 信封密文（base64(iv).base64(tag).base64(cipher)）
  ciphertext      String
  /// 展示用末 4 位
  last4           String
  /// 每日 token 上限；null = 不限
  dailyTokenLimit Int?
  createdAt       String
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, label])
}

model UsageRecord {
  id          String @id @default(cuid())
  userId      String
  /// 消耗发生在哪个应用
  productSlug String
  provider    String
  model       String
  tokensIn    Int
  tokensOut   Int
  costCents   Int
  /// YYYY-MM-DD
  day         String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, day])
}

model AppStorage {
  id          String @id @default(cuid())
  userId      String
  /// 应用隔离：每应用每用户独立命名空间
  productSlug String
  key         String
  value       String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productSlug, key])
}

model ActivityEvent {
  id           String  @id @default(cuid())
  actorName    String
  actorHue     Int
  actorIsAgent Boolean @default(false)
  verb         String
  productSlug  String?
  detail       String?
  /// Phase 1a 保留展示字符串（"12 分钟前"），Phase 1b 迁 DateTime
  at           String
  sort         Int
}

/// 站内通知（审核结果、收益、好友请求等）
model Notification {
  id        String  @id @default(cuid())
  userId    String
  /// review | earning | friend | system
  kind      String
  title     String
  body      String  @default("")
  href      String?
  read      Boolean @default(false)
  createdAt String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

/// 点数交易流水（充值/购买/退款）。支付为占位——真实支付网关待接入。
model CreditTransaction {
  id           String  @id @default(cuid())
  userId       String
  /// topup 充值 | purchase 购买 | refund 退款
  kind         String
  /// 正=入账（充值/退款），负=支出（购买）
  amount       Int
  /// 交易后余额
  balanceAfter Int
  note         String  @default("")
  /// 充值方式（wechat/alipay/card/demo）
  method       String?
  /// 关联产品 slug（购买/退款时）
  productSlug  String?
  createdAt    String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

/// 首页顶部大活动横幅（管理员后台可编辑/上下架/排序）
model Banner {
  id        String  @id @default(cuid())
  title     String
  subtitle  String  @default("")
  /// 小标签，如"限时 · 即日起至 6 月 30 日"
  badge     String  @default("")
  imageUrl  String
  /// 可选：动图/视频地址（mp4/webm），存在则覆盖静态图渲染
  videoUrl  String  @default("")
  href      String  @default("/#featured")
  active    Boolean @default(true)
  sort      Int     @default(0)
  createdAt String
}
