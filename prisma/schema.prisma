generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProductType {
  app
  model
  agent
  skill
  tutorial
  video
}

model User {
  id           String          @id @default(cuid())
  handle       String          @unique
  name         String
  avatarHue    Int
  level        Int
  signature    String          @default("")
  tokenBalance String          @default("0")
  /// [{ label, icon }]
  badges       Json            @default("[]")
  /// 展柜精选的产品 slug
  showcase     String[]        @default([])
  library      LibraryEntry[]
  friendsOut   FriendEdge[]    @relation("FriendA")
  friendsIn    FriendEdge[]    @relation("FriendB")
  credentials  ApiCredential[]
  usage        UsageRecord[]
}

model FriendEdge {
  id     String @id @default(cuid())
  aId    String
  bId    String
  status String @default("accepted")
  a      User   @relation("FriendA", fields: [aId], references: [id], onDelete: Cascade)
  b      User   @relation("FriendB", fields: [bId], references: [id], onDelete: Cascade)

  @@unique([aId, bId])
}

model Product {
  id           String         @id
  slug         String         @unique
  type         ProductType
  name         String
  tagline      String
  /// 段落数组
  description  String[]
  hueA         Int
  hueB         Int
  icon         String
  tags         String[]
  /// 展示用聚合（= base 社会证明 与平台内真实评测的混合值）
  ratingScore  Float
  ratingCount  Int
  /// 上架自带的历史评价社会证明（不以单条 Review 行存储），平台内新评测在此基础上混合
  baseRatingScore Float @default(0)
  baseRatingCount Int   @default(0)
  /// 近 10 期好评率（0-100）
  histogram    Int[]
  acquisitions Int
  developer    String
  version      String?
  /// 应用入口（沙箱加载的外部部署地址）
  entryUrl     String?
  /// null = 免费
  priceCredits Int?
  capabilities String[]
  releasedAt   String
  updatedAt    String
  featured     Boolean        @default(false)
  reviews      Review[]
  inLibraries  LibraryEntry[]
}

model Review {
  id         String  @id @default(cuid())
  productId  String
  /// 平台注册作者（防同一用户重复评测）；种子/Agent 评测为 null
  authorUserId String?
  /// 评测者去规范化（部分评测者非平台注册用户，如 Agent）
  authorName String
  avatarHue  Int
  isAgent    Boolean @default(false)
  score      Int
  usageHours Int
  helpful    Int     @default(0)
  body       String
  date       String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model LibraryEntry {
  id         String  @id @default(cuid())
  userId     String
  productId  String
  acquiredAt String
  lastUsedAt String?
  usageHours Int     @default(0)
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model ApiCredential {
  id              String  @id @default(cuid())
  userId          String
  /// anthropic | openai | google | xai | openrouter
  provider        String
  label           String
  /// AES-256-GCM 信封密文（base64(iv).base64(tag).base64(cipher)）
  ciphertext      String
  /// 展示用末 4 位
  last4           String
  /// 每日 token 上限；null = 不限
  dailyTokenLimit Int?
  createdAt       String
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, label])
}

model UsageRecord {
  id          String @id @default(cuid())
  userId      String
  /// 消耗发生在哪个应用
  productSlug String
  provider    String
  model       String
  tokensIn    Int
  tokensOut   Int
  costCents   Int
  /// YYYY-MM-DD
  day         String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, day])
}

model ActivityEvent {
  id           String  @id @default(cuid())
  actorName    String
  actorHue     Int
  actorIsAgent Boolean @default(false)
  verb         String
  productSlug  String?
  detail       String?
  /// Phase 1a 保留展示字符串（"12 分钟前"），Phase 1b 迁 DateTime
  at           String
  sort         Int
}
