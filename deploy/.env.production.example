# 模板。自测场景下仓库里已有填好真实值的 .env.production，无需再建此文件。
# 换数据库 / 换密钥时参考本模板覆盖 .env.production 即可。

# —— 数据库：复用 Lightsail 托管库，库名 postgres，单开一个 starport schema ——
# schema 由启动自举(pnpm db:bootstrap / pnpm start)自动 CREATE，无需手动建。
# sslmode 必须 no-verify（node 不信任 Lightsail/RDS 证书，require 会报 self-signed）。
# 密码含特殊字符要 URL 编码。
DATABASE_URL=postgresql://<user>:<URL编码密码>@<你的-ls-host>.rds.amazonaws.com:5432/postgres?sslmode=no-verify&schema=starport

# —— 会话 Cookie 加密口令（≥32 字符）—— 生成：openssl rand -hex 32
IRON_SESSION_PASSWORD=<openssl rand -hex 32>

# —— API Key 信封加密主密钥（设定后勿改，否则旧密文解不开）—— 生成：openssl rand -hex 32
STARPORT_SECRET=<openssl rand -hex 32>

# Node 环境（登录 Cookie 走 secure=true，仅 HTTPS）
NODE_ENV=production
